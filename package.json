{
  "name": "shareplate-connect",
  "version": "1.0.0",
  "private": true,
  "description": "MongoDB-backed food donation matching website",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js && node --check mongo-backend.js && node --check app.js",
    "db:check": "node -e \"const {MongoClient}=require('mongodb');const c=new MongoClient(process.env.MONGODB_URI||'mongodb://localhost:27017/');c.connect().then(()=>c.db(process.env.MONGODB_DB||'shareplate').command({ping:1})).then(()=>console.log('MongoDB connected')).finally(()=>c.close())\""
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "mongodb": "^7.5.0"
  }
}
